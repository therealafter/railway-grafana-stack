ARG VERSION=v3.2.1

FROM prom/prometheus:${VERSION}

# Copy the prom.yml configuration file to the container
COPY prom.yml /etc/prometheus/prom.yml

# Entrypoint que materializa o METRICS_TOKEN (env do Railway) em arquivo
# para o Prometheus ler via authorization.credentials_file
USER root
RUN printf '#!/bin/sh\nset -e\nif [ -n "$METRICS_TOKEN" ]; then\n  printf "%%s" "$METRICS_TOKEN" > /etc/prometheus/metrics_token\n  chmod 600 /etc/prometheus/metrics_token\n  chown nobody /etc/prometheus/metrics_token\nfi\nexec /bin/prometheus "$@"\n' > /entrypoint.sh \
  && chmod +x /entrypoint.sh \
  && chown nobody /etc/prometheus

USER nobody

ENTRYPOINT ["/entrypoint.sh"]
CMD ["--config.file=/etc/prometheus/prom.yml", "--storage.tsdb.path=/prometheus"]
